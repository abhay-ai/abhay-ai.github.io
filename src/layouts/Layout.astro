---
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="author" content="Abhay" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
  
  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</head>
<body>
  <div class="scroll-progress" id="scroll-progress"></div>
  <div class="site">
    <header class="header">
      <div class="brand">
        <a href="/" class="brand-link">Abhay</a>
        <a href="/" class="extra-link">home</a>
      </div>
      <ThemeToggle />
    </header>

    <main class="content-wrapper">
      <slot />
    </main>

    <footer class="footer">
      <div class="contact">
        <p class="contact-name">Abhay</p>
        <p class="contact-role">
          IBM R&D (2022-Present) &bull; ex-IAV (Automotive Tech) &bull; ex-<a href="http://www.eit.uni-kl.de/koenig" target="_blank" rel="noopener noreferrer">ISE TU Kaiserslautern</a>
        </p>
        <p class="contact-email">herr.abhay@gmail.com</p>
      </div>
    </footer>
  </div>

  <script is:inline>
    window.addEventListener('scroll', () => {
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      const progressEl = document.getElementById('scroll-progress');
      if (progressEl) progressEl.style.width = scrolled + '%';
    });
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg-color: #faf9f6; /* Warm soft white */
    --text-color: #1c1917; /* Soft stone charcoal */
    --accent-color: #c2410c; /* Rich terracotta */
    --muted-color: #78716c;
    --border-color: #e7e5e4;
    --code-bg: #f5f5f4;
    --link-color: #1d4ed8;
    --link-hover: #1e3a8a;
    --grid-dot-color: rgba(120, 113, 108, 0.12);
    --dashed-border-color: rgba(120, 113, 108, 0.35);
  }

  :root.dark {
    --bg-color: #121110; /* Warm obsidian black */
    --text-color: #e7e5e4; /* Warm stone white */
    --accent-color: #ea580c; /* Warm terracotta orange */
    --muted-color: #a8a29e; /* Warm stone gray */
    --border-color: #292524; /* Subtle dark border */
    --code-bg: #1c1917; /* Slate-stone dark code bg */
    --link-color: #f97316;
    --link-hover: #ffedd5;
    --grid-dot-color: rgba(168, 162, 158, 0.08);
    --dashed-border-color: rgba(168, 162, 158, 0.25);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    height: 100%;
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--bg-color);
    background-image: radial-gradient(var(--grid-dot-color) 1px, transparent 1px);
    background-size: 24px 24px;
    color: var(--text-color);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    line-height: 1.75;
    height: 100%;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  /* Core Layout */
  .site {
    max-width: 1040px;
    margin: 3rem auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    min-height: calc(100% - 6rem);
  }

  /* Scroll Progress Indicator */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background-color: var(--accent-color);
    width: 0%;
    z-index: 9999;
    transition: width 0.1s ease-out;
  }

  /* Header */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1.5px dashed var(--dashed-border-color);
    padding-bottom: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .brand {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
  }

  .brand-link {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--accent-color);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .brand-link:hover {
    opacity: 0.8;
  }

  .extra-link {
    font-size: 0.95rem;
    color: var(--muted-color);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .extra-link:hover {
    color: var(--text-color);
  }

  /* Content Wrapper */
  .content-wrapper {
    flex: 1;
    text-align: left;
  }

  /* Typography Elements */
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    color: var(--text-color);
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.3;
  }

  h1 { font-size: 1.85rem; font-weight: 700; }
  h2 { font-size: 1.5rem; border-bottom: 1.5px dashed var(--dashed-border-color); padding-bottom: 0.4rem; }
  h3 { font-size: 1.25rem; }

  p {
    margin-bottom: 1.5rem;
  }

  a {
    color: var(--link-color);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--link-hover);
    text-decoration: underline;
  }

  /* Lists */
  ul, ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }

  /* Code Block Styling */
  pre {
    background-color: var(--code-bg);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9rem;
  }

  code {
    background-color: var(--code-bg);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.15rem 0.3rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9rem;
  }

  pre code {
    background-color: transparent;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  /* Images */
  img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 1.5rem auto;
    border: 1px solid var(--border-color);
  }

  .image-caption, figcaption {
    font-size: 0.875rem;
    color: var(--muted-color);
    text-align: center;
    margin-top: -0.75rem;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  /* Footer */
  .footer {
    font-size: 0.875rem;
    color: var(--muted-color);
    border-top: 1px solid var(--border-color);
    margin-top: 3rem;
    padding-top: 1.5rem;
    line-height: 1.6;
  }

  .contact-name {
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 0.25rem;
  }

  .contact-role {
    margin-bottom: 0.25rem;
  }

  .contact-role a {
    color: var(--accent-color);
    text-decoration: underline;
  }

  .contact-role a:hover {
    color: var(--text-color);
  }

  .contact-email {
    font-family: monospace;
  }
</style>
