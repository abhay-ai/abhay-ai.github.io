---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');

const postsWithDates = allPosts.map(p => {
  const match = p.slug.match(/^(\d{4}-\d{2}-\d{2})-(.+)$/);
  const dateStr = match ? match[1] : '2010-01-01';
  return {
    slug: p.slug,
    title: p.data.title,
    date: dateStr,
  };
});

postsWithDates.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const recentPosts = postsWithDates
  .filter(p => p.slug !== post.slug)
  .slice(0, 3);

const match = post.slug.match(/^(\d{4}-\d{2}-\d{2})-(.+)$/);
const postDate = match ? match[1] : '2010-01-01';
---

<PostLayout 
  title={post.data.title} 
  date={postDate} 
  subtitle={post.data.subtitle} 
  recentPosts={recentPosts}
>
  <Content />
</PostLayout>
